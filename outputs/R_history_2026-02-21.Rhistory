sprintf("%.3f", p)
)
) |>
dplyr::select(Predictor, Model, b_se, p_fmt) |>
tidyr::pivot_wider(
names_from = Model,
values_from = c(b_se, p_fmt),
names_glue = "{Model}_{.value}"
)
